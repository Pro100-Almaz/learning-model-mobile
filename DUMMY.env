# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Clerk — get the publishable key from https://dashboard.clerk.com (API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Qadam backend API base URL (same API the web app uses).
# Not wired into the app yet — added here for when we build the API client.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
